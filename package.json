{
  "name": "keyboard-stats",
  "version": "1.0.0",
  "description": "科技感键盘按键统计桌面工具",
  "main": "dist-electron/main.js",
  "author": "Keyboard Stats",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:win": "vue-tsc --noEmit && vite build && electron-builder --win",
    "preview": "vite preview"
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.54.0",
    "better-sqlite3": "^11.0.0",
    "dayjs": "^1.11.11",
    "echarts": "^5.5.0",
    "exceljs": "^4.4.0",
    "vue": "^3.4.27",
    "vue-echarts": "^7.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.12",
    "@vitejs/plugin-vue": "^5.0.5",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.19"
  },
  "build": {
    "appId": "com.keyboard.stats",
    "productName": "KeyboardStats",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
